// 这个文件不会被 "docusaurus start/build" 命令使用。
// 它用于改善 IDE 体验（类型检查、自动补全等），
// 也可以配合 package.json 中的 "typecheck" 脚本手动运行。
{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": true
  },
  "exclude": [
    ".docusaurus",
    "build"
  ]
}
